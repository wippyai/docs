---
import Default from '@astrojs/starlight/components/Head.astro'

// Extend Starlight's <Head> so every page keeps the default behaviour, plus a
// tiny module script that lazy-renders Mermaid diagrams. The mermaid bundle is
// dynamically imported, so it only loads on pages that actually contain a
// diagram — pages without one ship no mermaid JavaScript at all.
const props = Astro.props
---
<Default {...props} />
<script type="module">
  const blocks = document.querySelectorAll('pre[data-language="mermaid"]')
  if (blocks.length) {
    const { default: mermaid } = await import('mermaid')
    const dark = document.documentElement.dataset.theme === 'dark'
    mermaid.initialize({
      startOnLoad: false,
      theme: dark ? 'dark' : 'default',
      securityLevel: 'loose',
    })
    // Expressive Code renders each source line in its own .ec-line element, so
    // pre.textContent would join them with no newlines and break parsing.
    // Reconstruct the source line by line.
    const targets = []
    for (const pre of blocks) {
      const lines = pre.querySelectorAll('.ec-line')
      const src = lines.length
        ? Array.from(lines, (l) => l.textContent).join('\n')
        : pre.textContent
      const div = document.createElement('div')
      div.className = 'mermaid'
      div.textContent = src
      pre.replaceWith(div)
      targets.push(div)
    }
    // suppressErrors + try/catch so a single malformed diagram never throws an
    // uncaught exception (which would tank Lighthouse Best Practices).
    try {
      await mermaid.run({ nodes: targets, suppressErrors: true })
    } catch (e) {
      /* ignore: a bad diagram renders as its source text */
    }
  }
</script>
