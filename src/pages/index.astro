---
// Browser-language landing page at "/". Astro emits this as a plain static
// HTML document (no SPA shell), so the inline script below runs immediately
// and redirects to the user's preferred locale. The meta refresh is a
// no-JS fallback to English.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="3; url=/en/" />
    <title>Wippy Documentation</title>
  </head>
  <body>
    <p style="font-family: system-ui, sans-serif; padding: 2rem">Redirecting to the documentation…</p>
    <script is:inline>
      (function () {
        var CODES = ['en', 'de', 'es', 'ja', 'ko', 'pt', 'ru', 'zh']
        var pick
        try {
          var saved = localStorage.getItem('wippy-docs-locale')
          if (saved && CODES.indexOf(saved) >= 0) pick = saved
        } catch (e) {}
        if (!pick) {
          var L =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || 'en']
          pick = 'en'
          for (var i = 0; i < L.length; i++) {
            var l = String(L[i] || '').toLowerCase()
            if (!l) continue
            if (CODES.indexOf(l) >= 0) {
              pick = l
              break
            }
            var b = l.split('-')[0]
            if (CODES.indexOf(b) >= 0) {
              pick = b
              break
            }
          }
        }
        try {
          localStorage.setItem('wippy-docs-locale', pick)
        } catch (e) {}
        location.replace('/' + pick + '/')
      })()
    </script>
  </body>
</html>
